@SET_MAKE@

CMAKE ?= cmake
BUILD_DIR ?= build
CMAKE_GENERATOR ?= Unix Makefiles
CMAKE_CONFIGURE_ARGS ?=
CMAKE_BUILD_ARGS ?=

PARALLEL_JOBS := $(shell printf '%s\n' "$(MAKEFLAGS)" | sed -n 's/.*-j\([0-9][0-9]*\).*/\1/p')
ifeq ($(strip $(PARALLEL_JOBS)),)
BUILD_PARALLEL_FLAG :=
else
BUILD_PARALLEL_FLAG := --parallel $(PARALLEL_JOBS)
endif

.PHONY: all server sql common login char map web tools import clean distclean help install uninstall bin-clean

all: ensure-configured
	@$(CMAKE) --build "$(BUILD_DIR)" $(BUILD_PARALLEL_FLAG) $(CMAKE_BUILD_ARGS)

sql:
	@echo "-!- 'make sql' is now deprecated. Please run 'make server' to continue. -!-"

server: ensure-configured
	@$(CMAKE) --build "$(BUILD_DIR)" $(BUILD_PARALLEL_FLAG) --target login-server char-server map-server web-server generate-import-files $(CMAKE_BUILD_ARGS)

common: ensure-configured
	@$(CMAKE) --build "$(BUILD_DIR)" $(BUILD_PARALLEL_FLAG) --target common $(CMAKE_BUILD_ARGS)

login: ensure-configured
	@$(CMAKE) --build "$(BUILD_DIR)" $(BUILD_PARALLEL_FLAG) --target login-server $(CMAKE_BUILD_ARGS)

char: ensure-configured
	@$(CMAKE) --build "$(BUILD_DIR)" $(BUILD_PARALLEL_FLAG) --target char-server $(CMAKE_BUILD_ARGS)

map: ensure-configured
	@$(CMAKE) --build "$(BUILD_DIR)" $(BUILD_PARALLEL_FLAG) --target map-server $(CMAKE_BUILD_ARGS)

web: ensure-configured
	@$(CMAKE) --build "$(BUILD_DIR)" $(BUILD_PARALLEL_FLAG) --target web-server $(CMAKE_BUILD_ARGS)

tools: ensure-configured
	@$(CMAKE) --build "$(BUILD_DIR)" $(BUILD_PARALLEL_FLAG) --target mapcache csv2yaml yaml2sql yamlupgrade $(CMAKE_BUILD_ARGS)

import: ensure-configured
	@$(CMAKE) --build "$(BUILD_DIR)" $(BUILD_PARALLEL_FLAG) --target generate-import-files $(CMAKE_BUILD_ARGS)

clean:
	@if test -f "$(BUILD_DIR)/CMakeCache.txt" ; then \
		$(CMAKE) --build "$(BUILD_DIR)" --target clean ; \
	fi

distclean: clean
	@rm -rf "$(BUILD_DIR)"

help:
	@echo "most common targets are 'all' 'server' 'import' 'clean' 'help'"
	@echo "possible targets are:"
	@echo "'all'         - configures (if needed) and builds everything via CMake"
	@echo "'server'      - builds login-server, char-server, map-server, web-server"
	@echo "'common'      - builds common static library target"
	@echo "'login'       - builds login server"
	@echo "'char'        - builds char server"
	@echo "'map'         - builds map server"
	@echo "'web'         - builds web server"
	@echo "'tools'       - builds mapcache, csv2yaml, yaml2sql, yamlupgrade"
	@echo "'import'      - generates conf/import, conf/msg_conf/import and db/import"
	@echo "'clean'       - runs CMake clean in build directory"
	@echo "'distclean'   - removes build directory"
	@echo "'install'     - runs CMake install"
	@echo "'help'        - outputs this message"

install: ensure-configured
	@$(CMAKE) --install "$(BUILD_DIR)"

bin-clean:
	@sh ./uninstall.sh bin

uninstall:
	@sh ./uninstall.sh all

ensure-configured:
	@if test ! -f "$(BUILD_DIR)/CMakeCache.txt" ; then \
		echo "Configuring CMake build in $(BUILD_DIR)"; \
		$(CMAKE) -S . -B "$(BUILD_DIR)" -G "$(CMAKE_GENERATOR)" $(CMAKE_CONFIGURE_ARGS) ; \
	fi
