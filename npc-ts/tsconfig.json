{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "Bundler",
    "lib": ["ES2022"],
    "strict": true,
    "noImplicitAny": true,
    "noImplicitReturns": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "rootDir": ".",
    "outDir": "./dist",
    "declaration": false,
    "sourceMap": true,
    "baseUrl": ".",
    "paths": {
      // Clean alias for type imports. Authors write:
      //   import type { NpcRegistration } from "@api";
      "@api":   ["./types/api"],
      // Shared helper modules. Authors write:
      //   import { confirm, paginatedMes } from "@lib/dialog";
      "@lib/*": ["./lib/*"]
    },
    "types": ["./types/api"]
  },
  "include": ["./**/*.ts", "./types/**/*.d.ts"],
  "exclude": ["node_modules", "dist"]
}
